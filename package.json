{
  "name": "@brandon-gottshall/review-game-core",
  "version": "0.2.2",
  "description": "Shared primitives for concept-tree review games: types, mastery math, scheduling, seeded generators, and a framework-agnostic well-formedness harness.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./workflow/session": {
      "types": "./src/workflow/session.ts",
      "default": "./src/workflow/session.ts"
    },
    "./workflow/persistence": {
      "types": "./src/workflow/persistence.ts",
      "default": "./src/workflow/persistence.ts"
    },
    "./workflow/debug": {
      "types": "./src/workflow/debug.ts",
      "default": "./src/workflow/debug.ts"
    },
    "./workflow/quiz-engine": {
      "types": "./src/workflow/quiz-engine.ts",
      "default": "./src/workflow/quiz-engine.ts"
    },
    "./workflow/rendering": {
      "types": "./src/workflow/rendering.ts",
      "default": "./src/workflow/rendering.ts"
    },
    "./wf-harness/vitest": {
      "types": "./src/wf-harness/vitest.ts",
      "default": "./src/wf-harness/vitest.ts"
    },
    "./wf-harness/jest": {
      "types": "./src/wf-harness/jest.ts",
      "default": "./src/wf-harness/jest.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "docs",
    "README.md",
    "tsconfig.build.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Brandon-Gottshall/review-game-core.git"
  },
  "license": "MIT",
  "author": "Brandon Gottshall"
}
